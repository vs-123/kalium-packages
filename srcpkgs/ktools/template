# Template file for 'ktools'
pkgname=ktools
version=26.03
revision=1
build_style=gnu-makefile
depends="curl git make spdx-licenses-list ktools-minimal-${version}_${revision}"
short_desc="Opinionated helpers for working with XBPS for Kalium Void"
maintainer="vs-123"
license="AGPLv3.0"
homepage="https://github.com/vs-123/ktools"
distfiles="https://github.com/vs-123/ktools/archive/refs/tags/v${version}.tar.gz"
wrksrc="ktools-${version}"
checksum=1f2600e20b0ba2cd33f2b83d1db756f61b7fffb90b2613d6498ebd6d6feaacbd
replaces="xtools>=0"

# all ktools that can function without git installed
# (git is by far the largest dependency)
_minimal=(xcheckrestart xchroot xclash xdbg xdeptree xdiff xdistdir xdowngrade
 xetcchanges xgenfstab xgrep xhog xi xilog xls xmksv xnews xnodev xoptdiff xpkg
 xq xrs xtree xuname xvoidstrap)

pkg_install() {
	for tool in "${_minimal[@]}"; do
		vmove usr/bin/$tool
		vmove usr/share/man/man1/$tool.1
		if [ -e "$DESTDIR/usr/share/fish/vendor_completions.d/$tool.fish" ]; then
			vmove usr/share/fish/vendor_completions.d/$tool.fish
		fi
	done
	vmove usr/share/man/man1/ktools.1
	vmove usr/share/zsh
	vmove usr/share/fish/vendor_functions.d
:
}

